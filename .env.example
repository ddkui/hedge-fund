# Model tier: 1 (CPU), 2 (GPU 24GB), 3 (64GB+)
MODEL_TIER=1

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_PRIMARY_MODEL=llama3.1:8b
OLLAMA_RESEARCH_MODEL=mistral:7b
OLLAMA_SHADOW_MODEL=phi3:mini

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# TimescaleDB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hedgefund
DB_USER=hedgefund
DB_PASSWORD=changeme

# Paper trading (set to false for live)
PAPER_TRADING=true

# Broker APIs
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Data APIs
NEWS_API_KEY=
FRED_API_KEY=

# Gmail (for notifications)
GMAIL_SENDER=
GMAIL_APP_PASSWORD=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Watchlists
STOCK_WATCHLIST=AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,SPY,QQQ
CRYPTO_WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT

# Risk management
KELLY_MULTIPLIER=0.25
RISK_MAX_POSITION_PCT=0.10
RISK_MAX_POSITIONS=10
RISK_MAX_DRAWDOWN_PCT=0.20
RISK_VAR_LIMIT_PCT=0.05
RISK_MAX_CORRELATED=3
INITIAL_CAPITAL=100000.0

# Gateway & security
GATEWAY_PORT=8000
JWT_SECRET=dev-secret-change-in-production
DASHBOARD_PASSWORD=hedgefund2026

# Capital.com (CFD broker — execution + price feed)
CAPITAL_COM_API_KEY=
CAPITAL_COM_IDENTIFIER=your-email@example.com
CAPITAL_COM_PASSWORD=
CAPITAL_COM_DEMO=true

CAPITAL_COM_LEVERAGE_FOREX=10
CAPITAL_COM_LEVERAGE_INDICES=5
CAPITAL_COM_LEVERAGE_COMMODITIES=5
CAPITAL_COM_LEVERAGE_SHARES=5

CAPITAL_COM_WATCHLIST=GOLD,EURUSD,US30,AAPL
